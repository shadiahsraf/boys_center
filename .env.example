# Copy this file to .env and fill in real values.
# .env is gitignored and loaded automatically by config/settings.py.

# ─── Django ──────────────────────────────────────────────────────────────
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Origins that may submit POSTs to this server. Include the SCHEME and PORT.
# Required when testing the QR check-in from a phone over LAN, or behind
# any reverse proxy. Example:
# DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000,http://192.168.1.10:8000
DJANGO_CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Public base URL embedded in attendance-session QR codes. If unset, the QR
# encodes a relative path which works only when scanned on the same host
# that served the page. For phone testing, set this to your LAN URL, e.g.:
# DJANGO_QR_BASE_URL=http://192.168.1.10:8000
DJANGO_QR_BASE_URL=

# ─── Database (PostgreSQL) ───────────────────────────────────────────────
# Option A — single URL (easiest, what most hosts use):
# DATABASE_URL=postgres://boys_user:boys_password@localhost:5432/boys_center

# Option B — discrete vars (used if DATABASE_URL is empty):
DB_ENGINE=django.db.backends.postgresql
DB_NAME=boys_center
DB_USER=boys_user
DB_PASSWORD=boys_password
DB_HOST=localhost
DB_PORT=5432

# Leave both DATABASE_URL and DB_NAME empty to fall back to local SQLite
# (handy for quick offline dev — but real deploys must use Postgres).
